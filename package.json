{
  "name": "opencoder-cli",
  "version": "1.0.0",
  "description": "AI coding assistant for your terminal — like Claude Code, but open source and multi-provider",
  "type": "module",
  "bin": {
    "opencoder": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "cli",
    "terminal",
    "claude-code",
    "gpt",
    "gemini",
    "ollama",
    "openrouter",
    "open-source"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/opencoder.git"
  },
  "homepage": "https://github.com/YOUR_USERNAME/opencoder#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/opencoder/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/google": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "@inquirer/prompts": "^7.0.0",
    "@slack/bolt": "^4.6.0",
    "ai": "^4.1.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "diff": "^7.0.0",
    "discord.js": "^14.25.1",
    "execa": "^9.6.1",
    "globby": "^14.1.0",
    "grammy": "^1.41.1",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ora": "^8.2.0",
    "react": "^18.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
